{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bot.schema.json",
  "title": "Bot",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "bot_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "prompt_file": {
      "type": "string",
      "minLength": 1
    },
    "default_workflow": {
      "type": "string"
    },
    "routes_to_agents": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "allowed_tools": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  },
  "required": [
    "bot_id",
    "name",
    "project_id",
    "role",
    "prompt_file"
  ]
}
